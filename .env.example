# --- LLM backend ---
OPENAI_API_KEY=

# --- Vector store (optional) ---
# QDRANT_URL=                    # managed Qdrant endpoint; unset → embedded :memory:

# --- Observability (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=   # e.g. http://localhost:4317 ; unset → console exporter
# OTEL_SERVICE_NAME=rag-llm-service

# --- Embedding cache tuning (optional) ---
# EVIDENCE_MAX_CACHE=2000
# EVIDENCE_ADAPTIVE_CACHE=true

# --- Logging ---
# ENV=dev                        # set to "prod" for single-line JSON logs
